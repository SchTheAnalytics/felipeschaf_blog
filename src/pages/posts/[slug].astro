---
import { render } from 'astro:content';
import { getPostPath, getPublicPosts, type PostEntry } from '../../data/posts';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getPublicPosts();

  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

interface Props {
  post: PostEntry;
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateFormatter = new Intl.DateTimeFormat('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
});
---

<BaseLayout title={post.data.title} description={post.data.description} canonicalPath={getPostPath(post)}>
  <article class="post-layout">
    <header class="post-header">
      <time datetime={post.data.date.toISOString()}>{dateFormatter.format(post.data.date)}</time>
      <h1>{post.data.title}</h1>
      <p class="post-description">{post.data.description}</p>
    </header>
    <div class="post-content">
      <Content />
    </div>
  </article>
</BaseLayout>
