---
import ArchiveNav from '../components/ArchiveNav.astro';
import PostList from '../components/PostList.astro';
import { site } from '../data/site';
import { getPublicPosts, groupPostsByArchive } from '../data/posts';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getPublicPosts();
const archive = groupPostsByArchive(posts);
---

<BaseLayout title={site.name} description={site.description} canonicalPath="/">
  <div class="page-shell">
    <div class="content-column">
      <section class="page-intro" aria-labelledby="home-title">
        <h1 id="home-title">{site.name}</h1>
        <p>{site.description}</p>
      </section>

      {
        posts.length === 0 ? (
          <p class="empty-state">Ainda nao ha posts publicados.</p>
        ) : (
          archive.map((year) =>
            year.months.map((month) => (
              <section class="archive-section" id={month.id} aria-labelledby={`${month.id}-title`}>
                <h2 class="archive-heading" id={`${month.id}-title`}>
                  {month.label} de {year.year}
                </h2>
                <PostList posts={month.posts} />
              </section>
            )),
          )
        )
      }
    </div>

    <ArchiveNav archive={archive} />
  </div>
</BaseLayout>
