---
import type { PostEntry } from '../data/posts';
import { getPostPath } from '../data/posts';

interface Props {
  posts: PostEntry[];
}

const { posts } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
});
---

<div class="post-list">
  {
    posts.map((post) => (
      <article class="post-card">
        <time datetime={post.data.date.toISOString()}>{dateFormatter.format(post.data.date)}</time>
        <h3>
          <a href={getPostPath(post)}>{post.data.title}</a>
        </h3>
        <p>{post.data.description}</p>
      </article>
    ))
  }
</div>
