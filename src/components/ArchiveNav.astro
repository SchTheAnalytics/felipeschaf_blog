---
import type { ArchiveYear } from '../data/posts';
import { getArchiveLabel } from '../data/posts';

interface Props {
  archive: ArchiveYear[];
}

const { archive } = Astro.props;
const months = archive.flatMap((year) =>
  year.months.map((month) => ({
    id: month.id,
    label: getArchiveLabel(year.year, month.label),
  })),
);
---

{
  archive.length > 0 && (
    <aside class="archive-nav" aria-label="Arquivo por ano e mes">
      <h2>Nesta página</h2>
      <ul class="archive-months">
        {months.map((month) => (
          <li>
            <a href={`#${month.id}`}>{month.label}</a>
          </li>
        ))}
      </ul>
    </aside>
  )
}
